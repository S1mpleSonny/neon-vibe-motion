        "code": "const { seededRandom, createRandomSequence } = window.__motionUtils; const sampleCache = new Map(); function getSamplePoints(img, density, seed, rotationDeg, imgScale) { if (!img || img.width === 0) return []; const cacheKey = `${img.src}_${density}_${rotationDeg}_${imgScale}`; if (sampleCache.has(cacheKey)) return sampleCache.get(cacheKey); const tempCanvas = document.createElement('canvas'); const tCtx = tempCanvas.getContext('2d'); const size = 200; tempCanvas.width = size; tempCanvas.height = size; tCtx.clearRect(0, 0, size, size); tCtx.save(); tCtx.translate(size / 2, size / 2); tCtx.rotate((rotationDeg * Math.PI) / 180); const imgAspect = img.width / img.height; const maxDraw = size * 0.7; let drawW, drawH; if (imgAspect > 1) { drawW = maxDraw; drawH = maxDraw / imgAspect; } else { drawH = maxDraw; drawW = maxDraw * imgAspect; } tCtx.drawImage(img, -drawW / 2, -drawH / 2, drawW, drawH); tCtx.restore(); const data = tCtx.getImageData(0, 0, size, size).data; const validPoints = []; for (let i = 0; i < data.length; i += 4) { if (data[i + 3] > 128) { const idx = i / 4; validPoints.push({ x: (idx % size) / size - 0.5, y: Math.floor(idx / size) / size - 0.5 }); } } const result = []; const random = seededRandom(seed); const count = Math.floor(validPoints.length * (density / 100) * imgScale * imgScale); if (validPoints.length > 0) { for (let i = 0; i < count; i++) { result.push(validPoints[Math.floor(random() * validPoints.length)]); } } sampleCache.set(cacheKey, result); return result; } const getTrajectory = (prog, seedIdx, i, canvasSize, gravityMult, roundness = 0, resistance = 0.85, spreadRand = 0) => { const rand = createRandomSequence(seedIdx * 2000 + i); let angle = rand() * Math.PI * 2; const speedRand = rand(); const jitterRand = rand(); if (spreadRand > 0) { angle += (jitterRand * 2 - 1) * spreadRand * 0.8; } const velocityScale = 1 - roundness * 0.7; const forceBase = 9.1; const force = forceBase * (0.8 + speedRand * 1.2 * velocityScale) * (1 + (jitterRand * 2 - 1) * spreadRand * 0.3); const t = prog * 30; const speedSum = (1 - Math.pow(resistance, t)) / (1 - resistance); const vx0 = Math.cos(angle) * force; const vy0 = Math.sin(angle) * force; const dx = vx0 * speedSum * (canvasSize * 0.0055); const gravityEffect = Math.pow(prog, 2.5) * (canvasSize * 0.45) * gravityMult * (1 - roundness * 0.5); const dy = vy0 * speedSum * (canvasSize * 0.0055) + gravityEffect; return { x: dx, y: dy }; }; function hexToRgb(hex) { const result = /^#?([a-f\\d]{2})([a-f\\d]{2})([a-f\\d]{2})$/i.exec(hex); return result ? { r: parseInt(result[1], 16), g: parseInt(result[2], 16), b: parseInt(result[3], 16) } : { r: 255, g: 255, b: 255 }; } function cubicBezier(p0, p1, p2, p3) { return function (t) { const cx = 3 * p0; const bx = 3 * (p2 - p0) - cx; const ax = 1 - cx - bx; const cy = 3 * p1; const by = 3 * (p3 - p1) - cy; const ay = 1 - cy - by; function sampleCurveX(t) { return ((ax * t + bx) * t + cx) * t; } function sampleCurveY(t) { return ((ay * t + by) * t + cy) * t; } function sampleCurveDerivativeX(t) { return (3 * ax * t + 2 * bx) * t + cx; } function solveCurveX(x) { let t2 = x; for (let i = 0; i < 5; i++) { const x2 = sampleCurveX(t2) - x; const d2 = sampleCurveDerivativeX(t2); if (Math.abs(x2) < 1e-6) return t2; if (Math.abs(d2) < 1e-6) break; t2 = t2 - x2 / d2; } return t2; } return sampleCurveY(solveCurveX(t)); }; } const easeInOut = cubicBezier(0.26, 1.00, 0.48, 1.00); function render(ctx, time, params, canvas) { const { width, height } = canvas; const canvasSize = Math.min(width, height); const themeColor = params.themeColor || '#fbff00'; const themeRgb = hexToRgb(themeColor); const density = params.particleDensity || 1.2; const stageTwoShapeGlow = params.stageTwoShapeGlow || 0; const gravityMult = params.gravityStrength !== undefined ? params.gravityStrength : 1.5; const tailMult = params.tailLengthMult || 2; const stageTwoTailMax = params.stageTwoTailMult !== undefined ? params.stageTwoTailMult : 1; const explosionCount = params.explosionParticleCount || 150; const outerGlowRadius = params.outerGlowRadius || 9; const showStageOne = params.showStageOne !== false; const stageTwoFinalScale = params.stageTwoFinalScale !== undefined ? params.stageTwoFinalScale : 1.1; const stageTwoFadeStartScale = params.stageTwoFadeStartScale !== undefined ? params.stageTwoFadeStartScale : 1.05; const tailThickness = params.tailThickness || 1.5; const randomThicknessMult = params.stageThreeRandomThickness !== undefined ? params.stageThreeRandomThickness : 0; const spreadRandVal = params.stageThreeSpreadRandomness !== undefined ? params.stageThreeSpreadRandomness : 0.5; const roundness = params.roundness !== undefined ? params.roundness : 0.5; const circularGlowIntensity = params.stageThreeCircularGlowIntensity !== undefined ? params.stageThreeCircularGlowIntensity : 5; const airResistance = params.explosionAirResistance || 0.85; ctx.clearRect(0, 0, width, height); const timeOffset = showStageOne ? 0 : 600; const adjustedTime = time + timeOffset; const stageOneEnd = 1000; const stageTwoStarts = [600, 800, 1000]; const stageTwoDuration = 2000; const stageThreeOffset = -1000; const stageThreeDuration = 2400; const images = [params.img1, params.img2, params.img3]; const showImages = [params.showImg1 !== false, params.showImg2 !== false, params.showImg3 !== false]; const imgScales = [params.img1Scale || 1, params.img2Scale || 1, params.img3Scale || 1]; const positions = [ { x: params.img1PosX !== undefined ? params.img1PosX : 0.7, y: params.img1PosY !== undefined ? params.img1PosY : 0.3 }, { x: params.img2PosX !== undefined ? params.img2PosX : 0.3, y: params.img2PosY !== undefined ? params.img2PosY : 0.5 }, { x: params.img3PosX !== undefined ? params.img3PosX : 0.7, y: params.img3PosY !== undefined ? params.img3PosY : 0.7 } ]; const rotations = [ params.img1Rotation !== undefined ? params.img1Rotation : 20, params.img2Rotation !== undefined ? params.img2Rotation : -20, params.img3Rotation !== undefined ? params.img3Rotation : 20 ]; if (showStageOne && adjustedTime < stageOneEnd) { const t = adjustedTime / stageOneEnd; const easeT = 1 - Math.pow(1 - t, 3); const curY = (height * 0.66) + (height * 0.5 - height * 0.66) * easeT; let rocketAlpha = (t < 0.2) ? t / 0.2 : (t > 0.6 ? Math.max(0, 1 - (t - 0.6) / 0.4) : 1.0); if (params.rocketImg instanceof HTMLImageElement) { const rocketScale = params.rocketScale || 2.0; const imgAspect = params.rocketImg.width / params.rocketImg.height; const baseSize = canvasSize * 0.1 * rocketScale; let drawW, drawH; if(imgAspect > 1) { drawW = baseSize; drawH = baseSize / imgAspect; } else { drawH = baseSize; drawW = baseSize * imgAspect; } ctx.save(); ctx.globalAlpha = rocketAlpha; ctx.translate(width / 2, curY); ctx.drawImage(params.rocketImg, -drawW / 2, -drawH / 2, drawW, drawH); ctx.restore(); } } images.forEach((img, idx) => { if (!showImages[idx]) return; const startTime = stageTwoStarts[idx]; if (adjustedTime < startTime) return; const centerX = width * positions[idx].x; const centerY = height * positions[idx].y; const baseSize = canvasSize * 0.5 * imgScales[idx]; const stageTwoEndTime = startTime + stageTwoDuration; const stageThreeStartTime = stageTwoEndTime + stageThreeOffset; if (adjustedTime < stageTwoEndTime) { const pTime = adjustedTime - startTime; const progress = Math.min(pTime / stageTwoDuration, 1.0); const easeProgress = easeInOut(progress); const currentScale = easeProgress * stageTwoFinalScale; const points = getSamplePoints(img, density, idx, rotations[idx], imgScales[idx]); const nextRand = createRandomSequence(adjustedTime + idx); ctx.save(); ctx.globalCompositeOperation = 'lighter'; let fadeAlpha = 1.0; if (currentScale >= stageTwoFadeStartScale) { const fadeProgress = (currentScale - stageTwoFadeStartScale) / (stageTwoFinalScale - stageTwoFadeStartScale); fadeAlpha = Math.max(0, 1 - fadeProgress); } ctx.globalAlpha = fadeAlpha; if (stageTwoShapeGlow > 0) { ctx.shadowColor = themeColor; ctx.shadowBlur = stageTwoShapeGlow * (canvasSize / 640); } ctx.translate(centerX, centerY); ctx.beginPath(); points.forEach((p) => { const px = p.x * baseSize * currentScale; const py = p.y * baseSize * currentScale; const angle = Math.atan2(py, px); const maxTailLen = (canvasSize * 0.05 + nextRand() * canvasSize * 0.03) * stageTwoTailMax; const growthFactor = Math.min(progress / 0.3, 1.0); const tailLen = maxTailLen * growthFactor * (1 - easeProgress * 0.8 + 0.2); ctx.moveTo(px, py); ctx.lineTo(px - Math.cos(angle) * tailLen, py - Math.sin(angle) * tailLen); }); ctx.strokeStyle = themeColor; ctx.lineWidth = (canvasSize * 0.0035) * Math.min(easeProgress * 2, 1); ctx.stroke(); ctx.beginPath(); points.forEach(p => { const px = p.x * baseSize * currentScale; const py = p.y * baseSize * currentScale; const coreRadius = (canvasSize * 0.003) * Math.min(easeProgress * 2, 1); ctx.moveTo(px + coreRadius, py); ctx.arc(px, py, coreRadius, 0, Math.PI * 2); }); const mixR = Math.round(255 * 0.6 + themeRgb.r * 0.4); const mixG = Math.round(255 * 0.6 + themeRgb.g * 0.4); const mixB = Math.round(255 * 0.6 + themeRgb.b * 0.4); ctx.fillStyle = `rgba(${mixR}, ${mixG}, ${mixB}, 0.9)`; ctx.fill(); ctx.restore(); } if (adjustedTime >= stageThreeStartTime) { const expTime = adjustedTime - stageThreeStartTime; const expProgress = Math.min(expTime / stageThreeDuration, 1); if (expProgress >= 1) return; const fadeIn = Math.min(expTime / 60, 1.0); const alpha = Math.pow(1 - expProgress, 2.3) * fadeIn; let sumX = 0, sumY = 0; for (let i = 0; i < explosionCount; i++) { const traj = getTrajectory(expProgress, idx, i, canvasSize, gravityMult, roundness, airResistance, spreadRandVal); sumX += traj.x; sumY += traj.y; } const avgX = centerX + sumX / explosionCount; const avgY = centerY + sumY / explosionCount; ctx.save(); ctx.globalCompositeOperation = 'lighter'; if (circularGlowIntensity > 0) { const maxR = canvasSize * 0.45 * expProgress * (1.3 + 0.5 * (1 - roundness)); const glowR = maxR * 2.25; const rgb = themeRgb; const circularGrad = ctx.createRadialGradient(avgX, avgY, 0, avgX, avgY, glowR); circularGrad.addColorStop(0, `rgba(${rgb.r}, ${rgb.g}, ${rgb.b}, ${0.25 * alpha * circularGlowIntensity})`); circularGrad.addColorStop(0.4, `rgba(${rgb.r}, ${rgb.g}, ${rgb.b}, ${0.1 * alpha * circularGlowIntensity})`); circularGrad.addColorStop(1, 'rgba(0, 0, 0, 0)'); ctx.fillStyle = circularGrad; ctx.beginPath(); ctx.arc(avgX, avgY, glowR, 0, Math.PI * 2); ctx.fill(); } ctx.lineCap = 'round'; ctx.lineJoin = 'round'; const rgb = themeRgb; const tailSteps = 15; const totalTailLength = 0.07 * tailMult; for (let i = 0; i < explosionCount; i++) { const particleRand = createRandomSequence(idx * 5000 + i); const sizeVariation = 1 + (particleRand() * 2 - 1) * randomThicknessMult; const offset = getTrajectory(expProgress, idx, i, canvasSize, gravityMult, roundness, airResistance, spreadRandVal); const curX = centerX + offset.x; const curY = centerY + offset.y; const baseWidth = canvasSize * 0.008 * tailThickness * (1 - expProgress) * sizeVariation; const grad = ctx.createLinearGradient(centerX, centerY, curX, curY); grad.addColorStop(0, `rgba(${rgb.r}, ${rgb.g}, ${rgb.b}, 0)`); grad.addColorStop(0.75, `rgba(${rgb.r}, ${rgb.g}, ${rgb.b}, ${alpha * 0.35})`); grad.addColorStop(1, `rgba(${rgb.r}, ${rgb.g}, ${rgb.b}, ${alpha * 0.85})`); ctx.beginPath(); for (let j = 0; j <= tailSteps; j++) { const tStep = Math.max(0, expProgress - (j / tailSteps) * totalTailLength); const p = getTrajectory(tStep, idx, i, canvasSize, gravityMult, roundness, airResistance, spreadRandVal); if (j === 0) ctx.moveTo(centerX + p.x, centerY + p.y); else ctx.lineTo(centerX + p.x, centerY + p.y); } ctx.lineWidth = baseWidth * 1.2; ctx.strokeStyle = grad; ctx.stroke(); const whiteGrad = ctx.createLinearGradient(centerX, centerY, curX, curY); whiteGrad.addColorStop(0, 'rgba(255, 255, 255, 0)'); whiteGrad.addColorStop(0.85, 'rgba(255, 255, 255, 0)'); whiteGrad.addColorStop(1, `rgba(255, 255, 255, ${alpha * 0.95})`); ctx.lineWidth = baseWidth * 0.45; ctx.strokeStyle = whiteGrad; ctx.stroke(); const pR = ((canvasSize * 0.0055 * (1 - expProgress)) + (canvasSize * 0.0004)) * sizeVariation; const glowR = pR * outerGlowRadius * (1 + (params.glowIntensity || 0)/100); const radialGrad = ctx.createRadialGradient(curX, curY, 0, curX, curY, glowR); radialGrad.addColorStop(0, `rgba(${rgb.r}, ${rgb.g}, ${rgb.b}, ${0.55 * alpha})`); radialGrad.addColorStop(0.3, `rgba(${rgb.r}, ${rgb.g}, ${rgb.b}, ${0.25 * alpha})`); radialGrad.addColorStop(1, `rgba(${rgb.r}, ${rgb.g}, ${rgb.b}, 0)`); ctx.fillStyle = radialGrad; ctx.fillRect(curX - glowR, curY - glowR, glowR * 2, glowR * 2); ctx.beginPath(); ctx.arc(curX, curY, pR, 0, Math.PI * 2); ctx.fillStyle = `rgba(255, 255, 255, ${0.95 * alpha})`; ctx.fill(); } ctx.restore(); } }); } window.__motionRender = render;",
