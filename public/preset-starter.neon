          }
        ],
        "code": "const CACHE = {\n  textPoints: {},\n  logoPoints: null,\n  lastLogoSrc: null,\n  timeline: null,\n  lastCount: null,\n  lastDuration: null,\n  offscreenCanvas: null\n};\n\nconst TEXT_LIST = ['2025', '新年快乐', '圣诞快乐', '干杯', 'BILIBILI'];\n\nfunction getTextPoints(text, canvas) {\n  if (CACHE.textPoints[text]) return CACHE.textPoints[text];\n  \n  const size = 100;\n  if (!CACHE.offscreenCanvas) CACHE.offscreenCanvas = document.createElement('canvas');\n  const ctx = CACHE.offscreenCanvas.getContext('2d');\n  CACHE.offscreenCanvas.width = size * 6;\n  CACHE.offscreenCanvas.height = size * 1.5;\n  \n  ctx.clearRect(0, 0, CACHE.offscreenCanvas.width, CACHE.offscreenCanvas.height);\n  ctx.font = `bold ${size}px \"Microsoft YaHei\", \"PingFang SC\", sans-serif`;\n  ctx.fillStyle = '#ffffff';\n  ctx.textAlign = 'center';\n  ctx.textBaseline = 'middle';\n  ctx.fillText(text, CACHE.offscreenCanvas.width / 2, size * 0.75);\n  \n  const imageData = ctx.getImageData(0, 0, CACHE.offscreenCanvas.width, CACHE.offscreenCanvas.height);\n  const points = [];\n  const step = 2;\n  for (let y = 0; y < CACHE.offscreenCanvas.height; y += step) {\n    for (let x = 0; x < CACHE.offscreenCanvas.width; x += step) {\n      if (imageData.data[(y * CACHE.offscreenCanvas.width + x) * 4 + 3] > 128) {\n        points.push({\n          x: (x - CACHE.offscreenCanvas.width / 2) / size,\n          y: (y - size * 0.75) / size\n        });\n      }\n    }\n  }\n  CACHE.textPoints[text] = points;\n  return points;\n}\n\nfunction getLogoPoints(img) {\n  if (!img || !(img instanceof HTMLImageElement)) return null;\n  if (CACHE.lastLogoSrc === img.src && CACHE.logoPoints) return CACHE.logoPoints;\n  \n  const size = 200;\n  if (!CACHE.offscreenCanvas) CACHE.offscreenCanvas = document.createElement('canvas');\n  const ctx = CACHE.offscreenCanvas.getContext('2d');\n  CACHE.offscreenCanvas.width = size;\n  CACHE.offscreenCanvas.height = size;\n  \n  const aspect = img.width / img.height;\n  let dw = size, dh = size;\n  if (aspect > 1) dh = size / aspect;\n  else dw = size * aspect;\n  \n  ctx.clearRect(0, 0, size, size);\n  ctx.drawImage(img, (size - dw)/2, (size - dh)/2, dw, dh);\n  \n  const imageData = ctx.getImageData(0, 0, size, size);\n  const points = [];\n  const step = 2;\n  for (let y = 0; y < size; y += step) {\n    for (let x = 0; x < size; x += step) {\n      if (imageData.data[(y * size + x) * 4 + 3] > 128) {\n        points.push({\n          x: (x - size / 2) / size,\n          y: (y - size / 2) / size\n        });\n      }\n    }\n  }\n  \n  CACHE.lastLogoSrc = img.src;\n  CACHE.logoPoints = points;\n  return points;\n}\n\n// 生成确定性的烟花时间表，支持数量变化\nfunction generateTimeline(duration, count) {\n  if (CACHE.timeline && CACHE.lastCount === count && CACHE.lastDuration === duration) return CACHE.timeline;\n  \n  const { createRandomSequence } = window.__motionUtils;\n  const timeline = [];\n  const seq = createRandomSequence(12345);\n  \n  // 单个烟花完整生命周期约为 3000ms (1000ms 上升 + 2000ms 爆炸)\n  // 确保最后一个烟花能完整播放，截止发射时间为 duration - 3000ms\n  const singleFireworkDuration = 3000;\n  let maxStartTime = duration - singleFireworkDuration;\n  \n  // 如果总时长太短，至少允许在开始时发射\n  if (maxStartTime < 0) maxStartTime = 0;\n  \n  for (let i = 0; i < count; i++) {\n    const typeRand = seq();\n    let type = 'normal';\n    \n    // 概率调整：LOGO 30%, 文字 50%, 普通 20%\n    if (typeRand < 0.3) {\n      type = 'logo';\n    } else if (typeRand < 0.8) {\n      type = 'text';\n    } else {\n      // 剩余20%中随机分配形状、双层或普通\n      const subRand = seq();\n      if (subRand > 0.6) type = 'shape';\n      else if (subRand > 0.3) type = 'double';\n      else type = 'normal';\n    }\n    \n    // 在允许的时间范围内均匀分布，加一点随机抖动\n    // 确保时间不超过 maxStartTime\n    const baseTime = i * (maxStartTime / Math.max(1, count));\n    const randomOffset = seq() * 400 - 200;\n    let startTime = baseTime + randomOffset;\n    \n    // 边界限制\n    startTime = Math.max(0, Math.min(startTime, maxStartTime));\n    \n    timeline.push({\n      id: i,\n      startTime: startTime, \n      x: 0.15 + seq() * 0.7, \n      targetY: 0.15 + seq() * 0.25, \n      hue: Math.floor(seq() * 360),\n      type: type,\n      textIndex: Math.floor(seq() * TEXT_LIST.length),\n      shapeType: seq() > 0.5 ? 'heart' : 'star'\n    });\n  }\n  \n  // 按时间排序确保渲染顺序\n  timeline.sort((a, b) => a.startTime - b.startTime);\n  \n  CACHE.timeline = timeline;\n  CACHE.lastCount = count;\n  CACHE.lastDuration = duration;\n  return timeline;\n}\n\nfunction render(ctx, time, params, canvas) {\n  const { width, height } = canvas;\n  const { createRandomSequence } = window.__motionUtils;\n  \n  const duration = params.durationTime || 5000;\n  const gravity = (params.gravity || 200) * height / 1000;\n  const friction = params.friction || 0.95;\n  const baseParticleCount = params.particleCount || 650;\n  const explosionScale = params.explosionSize || 1.0;\n  const shapeRandomness = params.shapeRandomness || 0.2;\n  const fireworkCount = params.fireworkCount || 15;\n  \n  ctx.globalCompositeOperation = 'lighter';\n  \n  const timeline = generateTimeline(duration, fireworkCount);\n  const launchDuration = 1000;\n  const explosionDuration = 2000;\n  \n  const calcPos = (vx, vy, t, startX, startY) => {\n    const drag = Math.pow(friction, t * 60);\n    const effectiveTime = (1 - drag) / Math.max(0.001, 1 - friction);\n    const x = startX + vx * effectiveTime * 0.05;\n    let y = startY + vy * effectiveTime * 0.05;\n    y += 0.5 * gravity * t * t;\n    return { x, y };\n  };\n\n  timeline.forEach(fw => {\n    const lifeTime = time - fw.startTime;\n    if (lifeTime < 0 || lifeTime > (launchDuration + explosionDuration)) return;\n    \n    if (lifeTime < launchDuration) {\n      const progress = lifeTime / launchDuration;\n      const yProgress = 1 - (1 - progress) * (1 - progress);\n      \n      const currentX = fw.x * width;\n      const startY = height;\n      const endY = fw.targetY * height;\n      const currentY = startY - (startY - endY) * yProgress;\n      \n      const trailLen = height * 0.05 * (1 - progress);\n      ctx.beginPath();\n      ctx.moveTo(currentX, currentY);\n      ctx.lineTo(currentX, currentY + trailLen);\n      ctx.strokeStyle = `hsla(${fw.hue}, 100%, 70%, ${1 - progress})`;\n      ctx.lineWidth = width * 0.004;\n      ctx.lineCap = 'round';\n      ctx.stroke();\n      \n      ctx.beginPath();\n      ctx.arc(currentX, currentY, width * 0.006, 0, Math.PI * 2);\n      ctx.fillStyle = `hsl(${fw.hue}, 100%, 90%)`;\n      ctx.fill();\n    } \n    else {\n      const explosionTime = (lifeTime - launchDuration) / 1000;\n      const centerX = fw.x * width;\n      const centerY = fw.targetY * height;\n      \n      const rand = createRandomSequence(fw.id * 1000);\n      \n      let points = null;\n      let pCount = baseParticleCount;\n      let velocityScale = width * 0.3 * explosionScale;\n      \n      if (fw.type === 'logo' && params.logoImage) {\n        points = getLogoPoints(params.logoImage);\n        if (points) {\n           pCount = points.length;\n           velocityScale = width * 0.2 * (params.logoScale || 1);\n        } else {\n           fw.type = 'normal';\n        }\n      } else if (fw.type === 'text') {\n        points = getTextPoints(TEXT_LIST[fw.textIndex], canvas);\n        if (points) {\n           pCount = points.length;\n           velocityScale = width * 0.3;\n        }\n      } else if (fw.type === 'shape') {\n        pCount = baseParticleCount * 0.8; \n      }\n      \n      const step = Math.ceil(pCount / 1000);\n      \n      for (let i = 0; i < pCount; i += step) {\n        const r1 = rand();\n        const r2 = rand();\n        const r3 = rand();\n        \n        let vx, vy;\n        \n        if (points) {\n           const p = points[i % points.length];\n           vx = p.x * velocityScale;\n           vy = p.y * velocityScale;\n           vx += (r1 - 0.5) * width * 0.05 * shapeRandomness;\n           vy += (r2 - 0.5) * width * 0.05 * shapeRandomness;\n        } else if (fw.type === 'shape') {\n           const angle = (i / pCount) * Math.PI * 2;\n           let x, y;\n           \n           if (fw.shapeType === 'star') {\n              const r = 1 + Math.sin(angle * 5) * 0.4;\n              x = r * Math.cos(angle - Math.PI/2);\n              y = r * Math.sin(angle - Math.PI/2);\n           } else {\n              x = 16 * Math.pow(Math.sin(angle), 3);\n              y = -(13 * Math.cos(angle) - 5 * Math.cos(2 * angle) - 2 * Math.cos(3 * angle) - Math.cos(4 * angle));\n              x /= 16;\n              y /= 16;\n           }\n           \n           vx = x * velocityScale * 0.6;\n           vy = y * velocityScale * 0.6;\n           \n           const spread = 0.9 + r2 * 0.2;\n           vx *= spread;\n           vy *= spread;\n           \n           vx += (r3 - 0.5) * width * 0.01 * shapeRandomness;\n           vy += (r3 - 0.5) * width * 0.01 * shapeRandomness;\n        } else {\n           const angle = r1 * Math.PI * 2;\n           const speed = r2 * velocityScale;\n           vx = Math.cos(angle) * speed;\n           vy = Math.sin(angle) * speed;\n        }\n        \n        let alpha = 1 - (explosionTime / (explosionDuration / 1000));\n        let hue = fw.hue;\n        let size = width * 0.003;\n        let isSecondary = false;\n        \n        let currentT = explosionTime;\n        let startX = centerX;\n        let startY = centerY;\n        let currentVx = vx;\n        let currentVy = vy;\n        \n        if (fw.type === 'double') {\n           const splitDelay = 0.5 + (r3 - 0.5) * 0.4;\n           if (explosionTime > splitDelay) {\n              isSecondary = true;\n              const subTime = explosionTime - splitDelay;\n              const subDuration = 1.0;\n              alpha = 1 - (subTime / subDuration);\n              \n              if (alpha > 0) {\n                  hue = (fw.hue + 120) % 360;\n                  const splitPos = calcPos(vx, vy, splitDelay, centerX, centerY);\n                  startX = splitPos.x;\n                  startY = splitPos.y;\n                  \n                  const subSpeed = velocityScale * 0.6;\n                  currentVx = vx * 0.3 + (r1 - 0.5) * subSpeed;\n                  currentVy = vy * 0.3 + (r2 - 0.5) * subSpeed;\n                  currentT = subTime;\n                  size *= 0.8;\n                  \n                  if (Math.sin(subTime * 30) > 0) alpha *= 0.8;\n              } else {\n                  alpha = 0;\n              }\n           }\n        }\n        \n        if (alpha > 0.01) {\n          const pos = calcPos(currentVx, currentVy, currentT, startX, startY);\n          \n          const trailDt = 0.06;\n          const prevT = Math.max(0, currentT - trailDt);\n          const prevPos = calcPos(currentVx, currentVy, prevT, startX, startY);\n          \n          ctx.beginPath();\n          ctx.moveTo(prevPos.x, prevPos.y);\n          ctx.lineTo(pos.x, pos.y);\n          ctx.lineWidth = size * 2.5;\n          ctx.strokeStyle = `hsla(${hue}, 100%, 60%, ${alpha * 0.4})`; \n          ctx.lineCap = 'round';\n          ctx.stroke();\n          \n          ctx.beginPath();\n          ctx.arc(pos.x, pos.y, size * 0.8, 0, Math.PI * 2);\n          ctx.fillStyle = `hsla(${hue}, 100%, 95%, ${alpha})`;\n          ctx.fill();\n        }\n      }\n    }\n  });\n  \n  ctx.globalAlpha = 1.0;\n}\n\nwindow.__motionRender = render;",
        "createdAt": 1767515664804,
        "updatedAt": 1768395066100
      },
