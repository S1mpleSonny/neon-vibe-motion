        "code": "function render(ctx, time, params, canvas) {\n  const { width, height } = canvas;\n  const video = params.mainVideo;\n  \n  const totalDuration = (video instanceof HTMLVideoElement && video.duration) \n    ? video.duration * 1000 \n    : 8000;\n  \n  const progress = Math.min(time / totalDuration, 1);\n\n  const angleDeg = params.angle || 45;\n  const angleRad = (angleDeg * Math.PI) / 180;\n  const blurAmount = params.blurStrength !== undefined ? params.blurStrength : 15;\n  const dimStrength = params.dimStrength !== undefined ? params.dimStrength : 0.25;\n  const lineColor = params.lineColor || '#f0e13d';\n  const baseLineWidth = params.lineWidth !== undefined ? params.lineWidth : 0.5;\n  const lineWidth = baseLineWidth * (Math.min(width, height) / 360 * 2);\n  const pauseRatio = params.pauseDuration || 0.3;\n  const glowScale = params.glowScale !== undefined ? params.glowScale : 1.5;\n\n  const moveTime = (1 - pauseRatio) / 2;\n  const t1 = moveTime;\n  const t2 = 1 - moveTime;\n\n  let moveProgress = 0;\n  const easeInOut = (t) => t < .5 ? 4 * t * t * t : (t - 1) * (2 * t - 2) * (2 * t - 2) + 1;\n\n  if (progress < t1) {\n    const p = progress / t1;\n    moveProgress = easeInOut(p) * 0.5;\n  } else if (progress < t2) {\n    moveProgress = 0.5;\n  } else {\n    const p = (progress - t2) / (1 - t2);\n    moveProgress = 0.5 + easeInOut(p) * 0.5;\n  }\n\n  const diag = Math.sqrt(width * width + height * height);\n  const maxDist = diag * 0.8;\n  const currentDist = (moveProgress - 0.5) * 2 * maxDist;\n\n  ctx.save();\n  ctx.fillStyle = '#000';\n  ctx.fillRect(0, 0, width, height);\n  \n  if (video instanceof HTMLVideoElement && video.readyState >= 2) {\n    const videoW = video.videoWidth;\n    const videoH = video.videoHeight;\n    const videoAspect = videoW / videoH;\n    const canvasAspect = width / height;\n    let drawW, drawH, drawX, drawY;\n\n    if (videoAspect > canvasAspect) {\n      drawH = height;\n      drawW = drawH * videoAspect;\n    } else {\n      drawW = width;\n      drawH = drawW / videoAspect;\n    }\n    drawX = (width - drawW) / 2;\n    drawY = (height - drawH) / 2;\n\n    ctx.save();\n    ctx.filter = `blur(${blurAmount}px)`;\n    const scale = 1.05;\n    ctx.drawImage(video, drawX - (drawW * (scale-1)/2), drawY - (drawH * (scale-1)/2), drawW * scale, drawH * scale);\n    ctx.restore();\n\n    if (dimStrength > 0) {\n      ctx.fillStyle = `rgba(0, 0, 0, ${dimStrength})`;\n      ctx.fillRect(0, 0, width, height);\n    }\n\n    ctx.save();\n    ctx.beginPath();\n    ctx.translate(width / 2, height / 2);\n    ctx.rotate(angleRad);\n    ctx.rect(-diag, -diag, currentDist + diag, 2 * diag);\n    ctx.restore();\n    ctx.clip();\n    ctx.drawImage(video, drawX, drawY, drawW, drawH);\n    ctx.restore();\n\n    ctx.save();\n    ctx.translate(width / 2, height / 2);\n    ctx.rotate(angleRad);\n    \n    const lineX = currentDist;\n    const halfDiag = diag; \n\n    const centerW = lineWidth * 1.5;\n    const edgeW = lineWidth * 0.5;\n    \n    const drawShuttlePath = (ctx, x, eW, cW, hD) => {\n      ctx.beginPath();\n      ctx.moveTo(x - eW/2, -hD);\n      ctx.lineTo(x - cW/2, 0);\n      ctx.lineTo(x - eW/2, hD);\n      ctx.lineTo(x + eW/2, hD);\n      ctx.lineTo(x + cW/2, 0);\n      ctx.lineTo(x + eW/2, -hD);\n      ctx.closePath();\n    };\n\n    const lineBodyGrad = ctx.createLinearGradient(0, -halfDiag, 0, halfDiag);\n    lineBodyGrad.addColorStop(0, lineColor + '20');\n    lineBodyGrad.addColorStop(0.2, lineColor);\n    lineBodyGrad.addColorStop(0.5, 'rgba(255, 255, 255, 0.7)'); \n    lineBodyGrad.addColorStop(0.8, lineColor);\n    lineBodyGrad.addColorStop(1, lineColor + '20');\n\n    ctx.save();\n    ctx.globalAlpha = 1.3; \n    ctx.shadowColor = lineColor;\n    // 光晕范围缩小50%：将原本的 lineWidth * 3 改为 lineWidth * 1.5\n    ctx.shadowBlur = lineWidth * glowScale;\n    drawShuttlePath(ctx, lineX, edgeW, centerW, halfDiag);\n    ctx.fillStyle = lineBodyGrad;\n    ctx.fill();\n    ctx.restore();\n    \n    ctx.save();\n    ctx.globalCompositeOperation = 'screen';\n    // 中心光晕范围同步缩小，使用 halfDiag * 0.2 代替 0.4\n    const centerBurst = ctx.createRadialGradient(lineX, 0, 0, lineX, 0, halfDiag * 0.2 * glowScale);\n    centerBurst.addColorStop(0, 'rgba(255, 255, 255, 0.4)'); \n    centerBurst.addColorStop(0.2, lineColor + '40');\n    centerBurst.addColorStop(1, 'rgba(0,0,0,0)');\n    ctx.translate(lineX, 0);\n    ctx.scale(0.3, 2.5);\n    ctx.translate(-lineX, 0);\n    ctx.fillStyle = centerBurst;\n    ctx.beginPath();\n    ctx.arc(lineX, 0, halfDiag * 0.2 * glowScale, 0, Math.PI*2);\n    ctx.fill();\n    ctx.restore();\n\n    ctx.restore();\n  }\n\n  if (params.showText !== false) {\n    const textYRatio = params.textYRatio || 0.7;\n    const textBaseY = height * textYRatio;\n    const centerX = width / 2;\n    const refSize = Math.min(width, height);\n    \n    const breathSpeed = params.breathSpeed || 4;\n    const breathTime = (time / 1000) * breathSpeed;\n    const breathOffset = Math.sin(breathTime) * (refSize * 0.01);\n    const breathOpacity = 0.8 + Math.sin(breathTime) * 0.2;\n\n    ctx.save();\n    const badgeHeight = refSize * 0.12;\n    const badgeWidth = badgeHeight * 1.8;\n    const radius = badgeHeight * 0.2;\n    \n    const offCanvas = document.createElement('canvas');\n    offCanvas.width = badgeWidth;\n    offCanvas.height = badgeHeight;\n    const offCtx = offCanvas.getContext('2d');\n    offCtx.fillStyle = '#FFFFFF';\n    offCtx.beginPath();\n    offCtx.roundRect(0, 0, badgeWidth, badgeHeight, radius);\n    offCtx.fill();\n    offCtx.globalCompositeOperation = 'destination-out';\n    offCtx.textAlign = 'center';\n    offCtx.textBaseline = 'middle';\n    offCtx.font = `900 ${badgeHeight * 0.65}px sans-serif`;\n    offCtx.fillText(\"4K\", badgeWidth / 2, badgeHeight / 2 + badgeHeight * 0.04);\n\n    ctx.globalAlpha = breathOpacity;\n    ctx.drawImage(offCanvas, centerX - badgeWidth / 2, textBaseY - badgeHeight / 2);\n\n    const sizeDesc = refSize * 0.04;\n    ctx.font = `${sizeDesc}px sans-serif`;\n    ctx.fillStyle = `rgba(255, 255, 255, ${breathOpacity})`;\n    ctx.textAlign = 'center';\n    ctx.textBaseline = 'top';\n    \n    const gap = badgeHeight * 0.3;\n    ctx.fillText(\"右滑邀您体验vivo 4K高清\", centerX, textBaseY + badgeHeight / 2 + gap + breathOffset);\n    ctx.restore();\n  }\n}\n\nwindow.__motionRender = render;",
        "createdAt": 1766647015444,
        "updatedAt": 1767075188974
      },
      "createdAt": 1766656489431,
      "updatedAt": 1766656489431
    }
  }
