        ],
        "code": "const offscreenCanvas = document.createElement('canvas');\nconst octx = offscreenCanvas.getContext('2d', { willReadFrequently: true });\n\nfunction hexToRgb(hex) {\n  const result = /^#?([a-f\\d]{2})([a-f\\d]{2})([a-f\\d]{2})$/i.exec(hex);\n  return result ? {\n    r: parseInt(result[1], 16),\n    g: parseInt(result[2], 16),\n    b: parseInt(result[3], 16)\n  } : { r: 0, g: 0, b: 0 };\n}\n\nfunction interpolateColor(color1, color2, factor, opacity = 0.8) {\n  const c1 = hexToRgb(color1);\n  const c2 = hexToRgb(color2);\n  const r = Math.round(c1.r + factor * (c2.r - c1.r));\n  const g = Math.round(c1.g + factor * (c2.g - c1.g));\n  const b = Math.round(c1.b + factor * (c2.b - c1.b));\n  return `rgba(${r}, ${g}, ${b}, ${opacity})`;\n}\n\nfunction extractSmoothOutline(img, threshold, scaleFactor, smoothness, canvas) {\n  const scanRes = 720;\n  const offRes = 400;\n  offscreenCanvas.width = offRes;\n  offscreenCanvas.height = offRes;\n  \n  octx.clearRect(0, 0, offRes, offRes);\n  octx.drawImage(img, 0, 0, offRes, offRes);\n  const imgData = octx.getImageData(0, 0, offRes, offRes).data;\n\n  let sumX = 0, sumY = 0, count = 0;\n  for (let y = 0; y < offRes; y++) {\n    for (let x = 0; x < offRes; x++) {\n      if (imgData[(y * offRes + x) * 4 + 3] > threshold) {\n        sumX += x; sumY += y; count++;\n      }\n    }\n  }\n  const midX = count > 0 ? sumX / count : offRes / 2;\n  const midY = count > 0 ? sumY / count : offRes / 2;\n\n  let rawPoints = [];\n  for (let i = 0; i < scanRes; i++) {\n    const angle = (i / scanRes) * Math.PI * 2;\n    const dx = Math.cos(angle);\n    const dy = Math.sin(angle);\n    let lastR = 0;\n    for (let r = offRes * 0.7; r > 0; r -= 1) {\n      const px = Math.floor(midX + dx * r);\n      const py = Math.floor(midY + dy * r);\n      if (px >= 0 && px < offRes && py >= 0 && py < offRes) {\n        if (imgData[(py * offRes + px) * 4 + 3] > threshold) {\n          lastR = r;\n          break;\n        }\n      }\n    }\n    rawPoints.push({ x: midX + dx * lastR, y: midY + dy * lastR });\n  }\n\n  let smoothedPoints = [];\n  const win = Math.max(1, Math.floor(smoothness));\n  const minDim = Math.min(canvas.width, canvas.height);\n  const visualScale = minDim * 0.8 * scaleFactor / offRes;\n  \n  for (let i = 0; i < scanRes; i++) {\n    let sx = 0, sy = 0, weightSum = 0;\n    for (let j = -win; j <= win; j++) {\n      const idx = (i + j + scanRes) % scanRes;\n      const weight = 1 - Math.abs(j) / (win + 1);\n      sx += rawPoints[idx].x * weight;\n      sy += rawPoints[idx].y * weight;\n      weightSum += weight;\n    }\n    smoothedPoints.push({\n      x: canvas.width / 2 + (sx / weightSum - offRes / 2) * visualScale,\n      y: canvas.height / 2 + (sy / weightSum - offRes / 2) * visualScale\n    });\n  }\n  \n  return { points: smoothedPoints };\n}\n\nfunction render(ctx, time, params, canvas) {\n  const { width, height } = canvas;\n  const minDim = Math.min(width, height);\n  const scaleRef = minDim / 640;\n\n  const { textString, outlineImage, flowSpeed, fontSize, glowAmount, glowStrength, glowOpacity, imageScale, alphaThreshold, smoothness, textColor, glowColorTop, glowColorBottom } = params;\n  \n  const relFontSize = fontSize * scaleRef;\n  const relGlow = glowAmount * scaleRef;\n  const relSpeed = flowSpeed * scaleRef;\n\n  let baseText = textString || \"Merry Christmas\";\n  // 如果用户没有输入空格，自动补一个空格以便循环连接\n  if (baseText.length > 0 && !baseText.endsWith(' ')) {\n    baseText += \" \";\n  }\n  if (baseText.length === 0) baseText = \"Merry Christmas \";\n  \n  let outlineData = { points: [] };\n  if (outlineImage instanceof HTMLImageElement && outlineImage.complete) {\n    outlineData = extractSmoothOutline(outlineImage, alphaThreshold, imageScale, smoothness, canvas);\n  } else {\n    const radius = minDim * 0.3 * imageScale;\n    const res = 720;\n    for (let i = 0; i < res; i++) {\n      const a = (i / res) * Math.PI * 2;\n      outlineData.points.push({ x: width/2 + Math.cos(a)*radius, y: height/2 + Math.sin(a)*radius });\n    }\n  }\n\n  const points = outlineData.points;\n  if (points.length < 10) return;\n\n  const pathData = [];\n  let totalLength = 0;\n  for (let i = 0; i < points.length; i++) {\n    const p = points[i];\n    const nextP = points[(i + 1) % points.length];\n    const dist = Math.sqrt((nextP.x - p.x)**2 + (nextP.y - p.y)**2);\n    pathData.push({ x: p.x, y: p.y, cumulative: totalLength, length: dist });\n    totalLength += dist;\n  }\n\n  const getPointAtDist = (d) => {\n    let target = ((d % totalLength) + totalLength) % totalLength;\n    let low = 0, high = pathData.length - 1, idx = 0;\n    while (low <= high) {\n      let mid = (low + high) >> 1;\n      if (pathData[mid].cumulative <= target) {\n        idx = mid;\n        low = mid + 1;\n      } else {\n        high = mid - 1;\n      }\n    }\n    const seg = pathData[idx];\n    const nextSeg = pathData[(idx + 1) % pathData.length];\n    const ratio = (target - seg.cumulative) / (seg.length || 1);\n    return {\n      x: seg.x + (nextSeg.x - seg.x) * ratio,\n      y: seg.y + (nextSeg.y - seg.y) * ratio\n    };\n  };\n\n  ctx.font = `bold ${relFontSize}px sans-serif`;\n  ctx.textAlign = 'center';\n  ctx.textBaseline = 'middle';\n\n  const charWidths = [];\n  let totalTextWidth = 0;\n  for (let i = 0; i < baseText.length; i++) {\n    const w = ctx.measureText(baseText[i]).width;\n    charWidths.push(w);\n    totalTextWidth += w;\n  }\n\n  const minSpacing = relFontSize * 0.05;\n  const singleLoopMinLen = totalTextWidth + (baseText.length * minSpacing);\n  const numReps = Math.max(1, Math.round(totalLength / singleLoopMinLen));\n  const totalGapSpace = totalLength - (numReps * totalTextWidth);\n  const finalSpacing = totalGapSpace / (numReps * baseText.length);\n  const charCount = numReps * baseText.length;\n\n  const charOffsets = new Float32Array(charCount);\n  let accumulatedDist = 0;\n  for (let i = 0; i < charCount; i++) {\n    const charIdx = i % baseText.length;\n    const w = charWidths[charIdx];\n    charOffsets[i] = accumulatedDist + w / 2;\n    accumulatedDist += w + finalSpacing;\n  }\n\n  const moveOffset = (time * 0.08 * relSpeed) % totalLength;\n  \n  let minY = Infinity, maxY = -Infinity;\n  points.forEach(p => {\n    if (p.y < minY) minY = p.y;\n    if (p.y > maxY) maxY = p.y;\n  });\n  const yRange = (maxY - minY) || 1;\n\n  for (let i = 0; i < charCount; i++) {\n    const baseDist = charOffsets[i];\n    const targetDist = (baseDist + moveOffset) % totalLength;\n    const pos = getPointAtDist(targetDist);\n    \n    const sampleStep = relFontSize * 0.2;\n    const pPrev = getPointAtDist(targetDist - sampleStep);\n    const pNext = getPointAtDist(targetDist + sampleStep);\n    const tangentAngle = Math.atan2(pNext.y - pPrev.y, pNext.x - pPrev.x);\n\n    const gradientFactor = Math.max(0, Math.min(1, (pos.y - minY) / yRange));\n    const currentCharGlowColor = interpolateColor(glowColorTop, glowColorBottom, gradientFactor, glowOpacity);\n    const char = baseText[i % baseText.length];\n\n    ctx.save();\n    ctx.translate(pos.x, pos.y);\n    ctx.rotate(tangentAngle);\n    \n    const adjustedBlur = relGlow * (1 + Math.log(glowStrength + 1) * 0.5);\n    \n    ctx.shadowBlur = adjustedBlur;\n    ctx.shadowColor = currentCharGlowColor;\n    ctx.fillStyle = currentCharGlowColor;\n    \n    // 第一层：广域辉光\n    ctx.fillText(char, 0, 0);\n    \n    // 第二层：核心加重\n    ctx.shadowBlur = adjustedBlur * 0.6;\n    ctx.fillText(char, 0, 0);\n\n    // 第三层：高亮核心\n    ctx.shadowBlur = adjustedBlur * 0.25;\n    ctx.fillText(char, 0, 0);\n    \n    // 绘制本体文字层\n    ctx.shadowBlur = 0;\n    ctx.fillStyle = textColor;\n    ctx.fillText(char, 0, 0);\n    ctx.restore();\n  }\n\n  const snowRandom = window.__motionUtils.createRandomSequence(42);\n  ctx.shadowBlur = 0;\n  ctx.fillStyle = \"rgba(255, 255, 255, 0.15)\";\n  for (let j = 0; j < 50; j++) {\n    const sx = snowRandom() * width;\n    const sy = ((snowRandom() * height) + (time * 0.03 * scaleRef)) % height;\n    const sSize = snowRandom() * 2.5 * scaleRef;\n    ctx.beginPath();\n    ctx.arc(sx, sy, sSize, 0, Math.PI * 2);\n    ctx.fill();\n  }\n}\n\nwindow.__motionRender = render;",
        "createdAt": 1767585578941,
        "updatedAt": 1768546160577
      },
      "createdAt": 1767680294376,
      "updatedAt": 1767680294376
    }
