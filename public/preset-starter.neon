        ],
        "code": "let points = [];\nlet lastText = '';\nlet lastCount = 0;\nlet lastPosRandom = 0;\nlet lastLenRandom = 0;\n\nfunction getPointsFromText(text, count, posRandom, lenRandom) {\n  const canvas = document.createElement('canvas');\n  const ctx = canvas.getContext('2d');\n  canvas.width = 1000;\n  canvas.height = 500;\n  \n  ctx.fillStyle = 'white';\n  ctx.font = 'bold 240px Arial';\n  ctx.textAlign = 'center';\n  ctx.textBaseline = 'middle';\n  \n  ctx.strokeStyle = 'white';\n  ctx.lineWidth = 4;\n  ctx.strokeText(text, 500, 250);\n  \n  const imageData = ctx.getImageData(0, 0, 1000, 500).data;\n  const edgePoints = [];\n  \n  for (let y = 10; y < 490; y += 1) {\n    for (let x = 10; x < 990; x += 1) {\n      const idx = (y * 1000 + x) * 4;\n      if (imageData[idx] > 50) {\n        edgePoints.push({ x: (x - 500) / 500, y: (y - 250) / 500 });\n      }\n    }\n  }\n  \n  const result = [];\n  const { seededRandomRange, seededRandomInt } = window.__motionUtils;\n  if (edgePoints.length === 0) return [];\n  \n  for (let i = 0; i < count; i++) {\n    const p = edgePoints[seededRandomInt(i, 0, edgePoints.length - 1)];\n    // 增加长度随机抖动，基于 lenRandom 参数\n    const lenVariation = seededRandomRange(i * 13, 1 - lenRandom, 1 + lenRandom);\n    const speedOffset = seededRandomRange(i * 17, 0.9, 1.1);\n    const isDissipating = (i % 5 === 0);\n    const dissipateScale = isDissipating ? seededRandomRange(i * 23, 1.03, 1.15) : 1.0;\n    \n    const offsetX = seededRandomRange(i * 31, -posRandom, posRandom);\n    const offsetY = seededRandomRange(i * 37, -posRandom, posRandom);\n    \n    result.push({ \n      x: p.x + offsetX, \n      y: p.y + offsetY, \n      id: i, \n      lenVariation, \n      speedOffset, \n      isDissipating, \n      dissipateScale\n    });\n  }\n  return result;\n}\n\nfunction render(ctx, time, params, canvas) {\n  const { width, height } = canvas;\n  const centerX = width / 2;\n  const centerY = height / 2;\n  const totalDuration = 5000;\n  \n  const currentCount = Math.floor(params.particleCount || 4000);\n  const currentPosRandom = params.posRandomness || 0.005;\n  const currentLenRandom = params.rayLengthRandom || 0.05;\n\n  if (lastText !== params.textString || lastCount !== currentCount || lastPosRandom !== currentPosRandom || lastLenRandom !== currentLenRandom || points.length === 0) {\n    points = getPointsFromText(params.textString || '2026', currentCount, currentPosRandom, currentLenRandom);\n    lastText = params.textString;\n    lastCount = currentCount;\n    lastPosRandom = currentPosRandom;\n    lastLenRandom = currentLenRandom;\n  }\n\n  const mainColor = params.mainColor || '#ff9500';\n  const rayLenRatio = params.rayLength || 0.1;\n  const originDepth = params.originDepth || 0.95;\n  const fadeOutStart = params.fadeOutStart || 0.5;\n  const fadeOutSpeed = params.fadeOutSpeed || 6.3;\n  const taperRatio = params.taperRatio !== undefined ? params.taperRatio : 0.8;\n  \n  const globalProgress = time / totalDuration;\n  let globalAlpha = 1.0;\n  if (globalProgress > fadeOutStart) {\n    globalAlpha = Math.max(0, 1.0 - (globalProgress - fadeOutStart) * fadeOutSpeed);\n  }\n  \n  ctx.globalCompositeOperation = 'lighter';\n  const baseScale = Math.min(width, height) * 0.8;\n  const baseLineWidth = Math.min(width, height) * 0.002;\n\n  const r = parseInt(mainColor.slice(1, 3), 16);\n  const g = parseInt(mainColor.slice(3, 5), 16);\n  const b = parseInt(mainColor.slice(5, 7), 16);\n\n  points.forEach((p) => {\n    const progress = (time / totalDuration) * p.speedOffset;\n    const clampedProgress = Math.min(1, progress);\n    \n    let easeVal;\n    if (p.isDissipating) {\n      easeVal = (1 - Math.pow(1 - clampedProgress, 3.2)) * p.dissipateScale;\n    } else {\n      easeVal = 1 - Math.pow(1 - clampedProgress, 4);\n    }\n\n    const tx = p.x * baseScale;\n    const ty = p.y * baseScale;\n    const ox = tx * (1 - originDepth);\n    const oy = ty * (1 - originDepth);\n    \n    const headX = ox + (tx - ox) * easeVal;\n    const headY = oy + (ty - oy) * easeVal;\n    \n    const individualRayLen = rayLenRatio * p.lenVariation;\n    const tailEase = Math.max(0, easeVal - individualRayLen);\n    const tailX = ox + (tx - ox) * tailEase;\n    const tailY = oy + (ty - oy) * tailEase;\n    \n    const drawHeadX = centerX + headX;\n    const drawHeadY = centerY + headY;\n    const drawTailX = centerX + tailX;\n    const drawTailY = centerY + tailY;\n\n    let alpha = Math.min(clampedProgress * 5, 1.0) * globalAlpha;\n    if (p.isDissipating) {\n      alpha *= Math.max(0, 1 - (clampedProgress - 0.7) * 3.33);\n    }\n\n    if (alpha <= 0) return;\n\n    const grad = ctx.createLinearGradient(drawTailX, drawTailY, drawHeadX, drawHeadY);\n    grad.addColorStop(0, `rgba(${r}, ${g}, ${b}, 0)`);\n    grad.addColorStop(0.1, `rgba(${r}, ${g}, ${b}, ${alpha * 0.2})`);\n    grad.addColorStop(0.85, `rgba(${r}, ${g}, ${b}, ${alpha * 0.95})`);\n    grad.addColorStop(1, `rgba(${r}, ${g}, ${b}, 0)`);\n\n    ctx.beginPath();\n    ctx.strokeStyle = grad;\n    ctx.lineWidth = baseLineWidth * (0.4 + (1.0 - taperRatio) * 0.6) * (0.7 + easeVal * 0.3);\n    ctx.lineCap = 'butt';\n    ctx.moveTo(drawTailX, drawTailY);\n    ctx.lineTo(drawHeadX, drawHeadY);\n    ctx.stroke();\n  });\n\n  ctx.globalCompositeOperation = 'screen';\n  const glowSize = Math.min(width, height) * 0.7;\n  const glow = ctx.createRadialGradient(centerX, centerY, 0, centerX, centerY, glowSize);\n  glow.addColorStop(0, `rgba(${r}, ${g}, ${b}, ${0.05 * globalAlpha})`);\n  glow.addColorStop(1, 'transparent');\n  ctx.fillStyle = glow;\n  ctx.fillRect(0, 0, width, height);\n}\n\nwindow.__motionRender = render;",
