        "code": "const { seededRandom, createRandomSequence } = window.__motionUtils;\n\nfunction render(ctx, time, params, canvas) {\n  const { width, height } = canvas;\n  const scale = Math.min(width / 1920, height / 1080);\n  const primaryColor = params.primaryColor || '#2563eb';\n  const accentColor = params.accentColor || '#8b5cf6';\n  const flowSpeed = params.flowSpeed || 2;\n\n  // 1. 背景绘制\n  if (params.showGrid) {\n    ctx.strokeStyle = 'rgba(148, 163, 184, 0.1)';\n    ctx.lineWidth = 1 * scale;\n    const gridSize = 60 * scale;\n    for (let x = 0; x <= width; x += gridSize) {\n      ctx.beginPath(); ctx.moveTo(x, 0); ctx.lineTo(x, height); ctx.stroke();\n    }\n    for (let y = 0; y <= height; y += gridSize) {\n      ctx.beginPath(); ctx.moveTo(0, y); ctx.lineTo(width, y); ctx.stroke();\n    }\n  }\n\n  // 2. 架构定义\n  const architecture = [\n    {\n      id: 'input',\n      title: 'INPUT INTERFACE',\n      color: '#3b82f6',\n      y: 0.15,\n      modules: [\n        { name: 'Chat Interface', desc: 'Natural Language Input' },\n        { name: 'Param Controller', desc: 'Manual Adjustment' }\n      ]\n    },\n    {\n      id: 'brain',\n      title: 'MOTION BRAIN (LLM)',\n      color: '#8b5cf6',\n      y: 0.38,\n      modules: [\n        { name: 'DSL Generator', desc: 'Code Generation' },\n        { name: 'Schema Validator', desc: 'JSON Integrity Check' },\n        { name: 'Context Manager', desc: 'History Memory' }\n      ]\n    },\n    {\n      id: 'state',\n      title: 'STATE & SYNC',\n      color: '#10b981',\n      y: 0.61,\n      modules: [\n        { name: 'Zustand Store', desc: 'Reactive State' },\n        { name: 'Time Sync', desc: 'Deterministic Timeline' }\n      ]\n    },\n    {\n      id: 'output',\n      title: 'HYBRID RENDERER',\n      color: '#f59e0b',\n      y: 0.84,\n      modules: [\n        { name: 'Canvas 2D', desc: 'Vector & Particles' },\n        { name: 'WebGL 3.0', desc: 'Three.js Shaders' },\n        { name: 'FFmpeg Export', desc: 'Frame-by-Frame' }\n      ]\n    }\n  ];\n\n  const modW = 280 * scale;\n  const modH = 80 * scale;\n  const layerH = 150 * scale;\n\n  // 3. 绘制连线逻辑\n  function drawFlowLine(x1, y1, x2, y2, isActive) {\n    ctx.beginPath();\n    ctx.strokeStyle = isActive ? primaryColor : '#cbd5e1';\n    ctx.lineWidth = (isActive ? 3 : 1) * scale;\n    ctx.setLineDash(isActive ? [] : [5*scale, 5*scale]);\n    \n    // 贝塞尔曲线连接\n    const cp1y = y1 + (y2 - y1) / 2;\n    const cp2y = y1 + (y2 - y1) / 2;\n    ctx.moveTo(x1, y1);\n    ctx.bezierCurveTo(x1, cp1y, x2, cp2y, x2, y2);\n    ctx.stroke();\n    ctx.setLineDash([]);\n\n    if (isActive) {\n      const t = (time * 0.001 * flowSpeed) % 1;\n      const getBezier = (t) => {\n        const invT = 1 - t;\n        return {\n          x: invT**3 * x1 + 3 * invT**2 * t * x1 + 3 * invT * t**2 * x2 + t**3 * x2,\n          y: invT**3 * y1 + 3 * invT**2 * t * cp1y + 3 * invT * t**2 * cp2y + t**3 * y2\n        };\n      };\n      const pos = getBezier(t);\n      ctx.fillStyle = primaryColor;\n      ctx.shadowBlur = 10 * scale;\n      ctx.shadowColor = primaryColor;\n      ctx.beginPath();\n      ctx.arc(pos.x, pos.y, 5 * scale, 0, Math.PI * 2);\n      ctx.fill();\n      ctx.shadowBlur = 0;\n    }\n  }\n\n  // 4. 渲染各层级\n  architecture.forEach((layer, lIdx) => {\n    const layerY = height * layer.y;\n    const layerProgress = Math.min(1, Math.max(0, (time - lIdx * 800) / 1000));\n    \n    if (layerProgress <= 0) return;\n\n    ctx.save();\n    ctx.globalAlpha = layerProgress;\n\n    // 绘制层背景标题\n    ctx.fillStyle = layer.color + '15';\n    ctx.beginPath();\n    ctx.roundRect(width * 0.1, layerY - layerH/2, width * 0.8, layerH, 15 * scale);\n    ctx.fill();\n\n    ctx.fillStyle = layer.color;\n    ctx.font = `bold ${22 * scale}px monospace`;\n    ctx.textAlign = 'left';\n    ctx.fillText(layer.title, width * 0.12, layerY - layerH/2 + 30 * scale);\n\n    // 绘制模块\n    layer.modules.forEach((mod, mIdx) => {\n      const totalModW = layer.modules.length * modW + (layer.modules.length - 1) * 40 * scale;\n      const startX = (width - totalModW) / 2 + modW / 2;\n      const modX = startX + mIdx * (modW + 40 * scale);\n      const modY = layerY + 10 * scale;\n\n      // 模块容器\n      const isActive = Math.floor(time / 2500) % architecture.length === lIdx;\n      const hover = isActive ? Math.sin(time * 0.005) * 5 * scale : 0;\n\n      ctx.fillStyle = '#ffffff';\n      ctx.shadowBlur = isActive ? 20 * scale : 5 * scale;\n      ctx.shadowColor = isActive ? layer.color + '66' : 'rgba(0,0,0,0.05)';\n      \n      ctx.beginPath();\n      ctx.roundRect(modX - modW/2, modY - modH/2 + hover, modW, modH, 8 * scale);\n      ctx.fill();\n      \n      ctx.strokeStyle = isActive ? layer.color : '#e2e8f0';\n      ctx.lineWidth = 2 * scale;\n      ctx.stroke();\n\n      // 文字内容\n      ctx.shadowBlur = 0;\n      ctx.fillStyle = '#1e293b';\n      ctx.font = `bold ${18 * scale}px sans-serif`;\n      ctx.textAlign = 'center';\n      ctx.fillText(mod.name, modX, modY + hover - 5 * scale);\n      \n      ctx.fillStyle = '#64748b';\n      ctx.font = `${14 * scale}px sans-serif`;\n      ctx.fillText(mod.desc, modX, modY + hover + 20 * scale);\n\n      // 连线到下一层\n      if (lIdx < architecture.length - 1) {\n        const nextLayer = architecture[lIdx + 1];\n        const nextY = height * nextLayer.y - layerH/2 + 10 * scale;\n        \n        // 找到下一层最接近的模块\n        const nextTotalModW = nextLayer.modules.length * modW + (nextLayer.modules.length - 1) * 40 * scale;\n        const nextStartX = (width - nextTotalModW) / 2 + modW / 2;\n        \n        nextLayer.modules.forEach((_, nmIdx) => {\n           if (mIdx === nmIdx || (mIdx === layer.modules.length-1 && nmIdx === nextLayer.modules.length-1)) {\n             const nX = nextStartX + nmIdx * (modW + 40 * scale);\n             drawFlowLine(modX, modY + modH/2 + hover, nX, nextY, isActive);\n           }\n        });\n      }\n    });\n    ctx.restore();\n  });\n\n  // 5. 侧边详细说明 (动态浮现)\n  const infoIdx = Math.floor(time / 5000) % 4;\n  const infoTexts = [\n    [\"Natural Language Understanding\", \"Transforms user intent into structured DSL\"],\n    [\"Deterministic Engine\", \"Ensures frame-perfect consistency across devices\"],\n    [\"Reactive State Management\", \"Real-time synchronization between UI and Canvas\"],\n    [\"Cloud-Ready Export\", \"High-bitrate video encoding from raw buffer data\"]\n  ];\n\n  ctx.save();\n  ctx.translate(width * 0.82, height * 0.4);\n  ctx.fillStyle = '#1e293b';\n  ctx.font = `bold ${24 * scale}px sans-serif`;\n  ctx.textAlign = 'left';\n  ctx.fillText(\"KEY FEATURES\", 0, 0);\n  \n  ctx.lineWidth = 4 * scale;\n  ctx.strokeStyle = primaryColor;\n  ctx.beginPath(); ctx.moveTo(0, 15*scale); ctx.lineTo(100*scale, 15*scale); ctx.stroke();\n\n  infoTexts[infoIdx].forEach((txt, i) => {\n    ctx.fillStyle = i === 0 ? '#334155' : '#64748b';\n    ctx.font = i === 0 ? `bold ${18 * scale}px sans-serif` : `${16 * scale}px sans-serif`;\n    ctx.fillText(txt, 0, 60 * scale + i * 30 * scale);\n  });\n  ctx.restore();\n\n  // 6. 底部进度条\n  const progress = time / 20000;\n  ctx.fillStyle = '#e2e8f0';\n  ctx.fillRect(0, height - 4 * scale, width, 4 * scale);\n  ctx.fillStyle = primaryColor;\n  ctx.fillRect(0, height - 4 * scale, width * progress, 4 * scale);\n}\n\nwindow.__motionRender = render;",
        "createdAt": 1767879038364,
        "updatedAt": 1767879178363
