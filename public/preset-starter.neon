        {
          "id": "msg_1768476270175_me7co6k",
          "role": "user",
          "content": "严格使用我提供的代码:\"const { seededRandom, createRandomSequence } = window.__motionUtils; const sampleCache = new Map();  function getSamplePoints(img, density, seed, rotationDeg, imgScale) {   if (!img || img.width === 0) return [];   const cacheKey = `${img.src}_${density}_${rotationDeg}_${imgScale}`;   if (sampleCache.has(cacheKey)) return sampleCache.get(cacheKey);    const tempCanvas = document.createElement('canvas');   const tCtx = tempCanvas.getContext('2d');   const size = 200;   tempCanvas.width = size;   tempCanvas.height = size;    tCtx.clearRect(0, 0, size, size);   tCtx.save();   tCtx.translate(size / 2, size / 2);   tCtx.rotate((rotationDeg * Math.PI) / 180);      const imgAspect = img.width / img.height;   const maxDraw = size * 0.7;   let drawW, drawH;   if (imgAspect > 1) {     drawW = maxDraw;     drawH = maxDraw / imgAspect;   } else {     drawH = maxDraw;     drawW = maxDraw * imgAspect;   }      tCtx.drawImage(img, -drawW / 2, -drawH / 2, drawW, drawH);   tCtx.restore();      const data = tCtx.getImageData(0, 0, size, size).data;   const validPoints = [];   for (let i = 0; i < data.length; i += 4) {     if (data[i + 3] > 128) {       const idx = i / 4;       validPoints.push({ x: (idx % size) / size - 0.5, y: Math.floor(idx / size) / size - 0.5 });     }   }    const result = [];   const random = seededRandom(seed);   const count = Math.floor(validPoints.length * (density / 100) * imgScale * imgScale);      if (validPoints.length > 0) {     for (let i = 0; i < count; i++) {       result.push(validPoints[Math.floor(random() * validPoints.length)]);     }   }   sampleCache.set(cacheKey, result);   return result; }  const getTrajectory = (prog, seedIdx, i, canvasSize, gravityMult, roundness = 0, resistance = 0.85) => {   const rand = createRandomSequence(seedIdx * 2000 + i);   const angle = rand() * Math.PI * 2;   const speedRand = rand();      const velocityScale = 1 - roundness * 0.7;   const forceBase = 9.1; // 阶段三初速度再次提升约10%   const force = forceBase * (0.8 + speedRand * 1.2 * velocityScale);      const t = prog * 30;   const speedSum = (1 - Math.pow(resistance, t)) / (1 - resistance);      const vx0 = Math.cos(angle) * force;   const vy0 = Math.sin(angle) * force;      const dx = vx0 * speedSum * (canvasSize * 0.0055);   const gravityEffect = Math.pow(prog, 2.5) * (canvasSize * 0.45) * gravityMult * (1 - roundness * 0.5);   const dy = vy0 * speedSum * (canvasSize * 0.0055) + gravityEffect;      return { x: dx, y: dy }; };  function hexToRgb(hex) {   const result = /^#?([a-f\\d]{2})([a-f\\d]{2})([a-f\\d]{2})$/i.exec(hex);   return result ? { r: parseInt(result[1], 16), g: parseInt(result[2], 16), b: parseInt(result[3], 16) } : { r: 255, g: 255, b: 255 }; } function cubicBezier(p0, p1, p2, p3) {   return function (t) {     const cx = 3 * p0;     const bx = 3 * (p2 - p0) - cx;     const ax = 1 - cx - bx;      const cy = 3 * p1;     const by = 3 * (p3 - p1) - cy;     const ay = 1 - cy - by;      function sampleCurveX(t) {       return ((ax * t + bx) * t + cx) * t;     }      function sampleCurveY(t) {       return ((ay * t + by) * t + cy) * t;     }      function sampleCurveDerivativeX(t) {       return (3 * ax * t + 2 * bx) * t + cx;     }      // Newton–Raphson 迭代求解 x = t     function solveCurveX(x) {       let t2 = x;       for (let i = 0; i < 5; i++) {         const x2 = sampleCurveX(t2) - x;         const d2 = sampleCurveDerivativeX(t2);         if (Math.abs(x2) < 1e-6) return t2;         if (Math.abs(d2) < 1e-6) break;         t2 = t2 - x2 / d2;       }       return t2;     }      return sampleCurveY(solveCurveX(t));   }; } const easeInOut = cubicBezier(0.42, 0.00, 0.58, 1.00); function render(ctx, time, params, canvas) {   const { width, height } = canvas;   const canvasSize = Math.min(width, height);   const themeColor = params.themeColor || '#fbff00';   const themeRgb = hexToRgb(themeColor);   const density = params.particleDensity || 1.2;   const stageTwoShapeGlow = params.stageTwoShapeGlow || 0;   const gravityMult = params.gravityStrength !== undefined ? params.gravityStrength : 1.5;   const tailMult = params.tailLengthMult || 2;   const stageTwoTail = params.stageTwoTailMult !== undefined ? params.stageTwoTailMult : 1;   const explosionCount = params.explosionParticleCount || 150;   const blurPower = params.transitionBlur || 10;   const outerGlowRadius = params.outerGlowRadius || 9;   const dissipateScale = params.stageTwoDissipateScale || 1.8;   const showStageOne = params.showStageOne !== false;   const idleScaleSpeed = params.idleScaleSpeed || 0.15;   const tailThickness = params.tailThickness || 1.5;   const roundness = params.roundness !== undefined ? params.roundness : 0.5;   const circularGlowIntensity = params.stageThreeCircularGlowIntensity !== undefined ? params.stageThreeCircularGlowIntensity : 5;   const airResistance = params.explosionAirResistance || 0.85;    ctx.clearRect(0, 0, width, height);    const timeOffset = showStageOne ? 0 : 600;   const adjustedTime = time + timeOffset;    const stageOneEnd = 1000;   const stageTwoStarts = [600, 800, 1000];    const stageTwoDuration = 1200;   const dissipateTrigger = 1800;   const stageThreeStart = dissipateTrigger - 100;    const stageThreeDuration = 2400; // 阶段三持续时间再次缩短约15% (从2800缩短到2400)    const images = [params.img1, params.img2, params.img3];   const imgScales = [params.img1Scale || 1, params.img2Scale || 1, params.img3Scale || 1];   const positions = [{ x: 0.7, y: 0.3 }, { x: 0.3, y: 0.5 }, { x: 0.7, y: 0.7 }];   const rotations = [20, -20, 20];    if (showStageOne && adjustedTime < stageOneEnd) {     const t = adjustedTime / stageOneEnd;     const easeT = 1 - Math.pow(1 - t, 3);     const curY = (height * 0.66) + (height * 0.5 - height * 0.66) * easeT;     let rocketAlpha = (t < 0.2) ? t / 0.2 : (t > 0.6 ? Math.max(0, 1 - (t - 0.6) / 0.4) : 1.0);      if (params.rocketImg instanceof HTMLImageElement) {       const rocketScale = params.rocketScale || 2.0;       const imgAspect = params.rocketImg.width / params.rocketImg.height;       const baseSize = canvasSize * 0.1 * rocketScale;       let drawW, drawH;       if(imgAspect > 1) { drawW = baseSize; drawH = baseSize / imgAspect; }        else { drawH = baseSize; drawW = baseSize * imgAspect; }       ctx.save();       ctx.globalAlpha = rocketAlpha;       ctx.translate(width / 2, curY);       ctx.drawImage(params.rocketImg, -drawW / 2, -drawH / 2, drawW, drawH);       ctx.restore();     }   }    images.forEach((img, idx) => {     const startTime = stageTwoStarts[idx];     if (adjustedTime < startTime) return;          const centerX = width * positions[idx].x;     const centerY = height * positions[idx].y;     const baseSize = canvasSize * 0.5 * imgScales[idx];     // 阶段二     if (adjustedTime < stageThreeStart + 800) {       const pTime = adjustedTime - startTime;       const progress = Math.min(pTime / stageTwoDuration, 1.0);       const easeProgress = easeInOut(progress);       const idleTime = Math.max(0, (adjustedTime - (startTime + stageTwoDuration)) / 1000);       const idleScale = 1 + idleTime * idleScaleSpeed;       let dissipateProgress = 0;       const dissipateDuration = 800;       if (adjustedTime > dissipateTrigger) dissipateProgress = Math.min((adjustedTime - dissipateTrigger) / dissipateDuration, 1.0);       const smoothDissipate = dissipateProgress < 0.5 ? 2 * dissipateProgress * dissipateProgress : 1 - Math.pow(-2 * dissipateProgress + 2, 2) / 2;       const currentScale = idleScale + smoothDissipate * (dissipateScale - 1);       const opacity = adjustedTime > dissipateTrigger ? Math.max(0, 1 - Math.pow(dissipateProgress, 2.0)) : 1.0;        const points = getSamplePoints(img, density, idx, rotations[idx], imgScales[idx]);       const nextRand = createRandomSequence(adjustedTime + idx);        ctx.save();       ctx.globalAlpha = opacity;       ctx.globalCompositeOperation = 'lighter';              let currentBlur = 0;       if (progress < 0.25) currentBlur = (0.25 - progress